# App URL (set to your Render URL for deployed environments)
# APP_URL=https://your-app.onrender.com

# Google OAuth (from Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# Anthropic API (for AI analysis reports)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=

# Optional: override AdSense account ID (auto-discovered if not set)
# ADSENSE_ACCOUNT_ID=accounts/pub-XXXXXXXXXXXXXXXX
