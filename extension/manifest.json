{
  "manifest_version": 3,
  "name": "AdSense Dashboard Helper",
  "version": "4.0",
  "description": "解决 AdSense API 浏览器 CORS 限制",
  "permissions": [],
  "host_permissions": [
    "https://adsense.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://suda-go.github.io/*", "http://localhost:*/*"],
      "js": ["content-isolated.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://suda-go.github.io/*", "http://localhost:*/*"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
