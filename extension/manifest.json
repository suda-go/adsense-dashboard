{
  "manifest_version": 3,
  "name": "AdSense Dashboard Helper",
  "version": "4.0",
  "description": "\u89e3\u51b3 AdSense API \u6d4f\u89c8\u5668 CORS \u9650\u5236",
  "permissions": [],
  "host_permissions": [
    "https://adsense.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://suda-go.github.io/*",
        "http://localhost:*/*"
      ],
      "js": [
        "content-isolated.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://suda-go.github.io/*",
        "http://localhost:*/*"
      ],
      "js": [
        "content-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}